{
  "name": "@cleverjs/toolkit",
  "version": "1.1.1",
  "description": "TypeScript toolkit with utilities, helpers, and MikroORM repository patterns for building applications",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "build": "swc ./src -d ./dist --strip-leading-paths --source-maps && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "prebuild": "pnpm clean",
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo",
    "prepublishOnly": "npm run build",
    "tests": "vitest --config vitest.config.ts",
    "test-coverage": "vitest run --coverage --config vitest.config.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./objects": {
      "types": "./dist/types/objects.d.ts",
      "require": "./dist/objects.js",
      "import": "./dist/objects.js",
      "default": "./dist/objects.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "AGENTS_INSTRUCTION.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cleverJS/toolkit.git"
  },
  "keywords": [
    "typescript",
    "toolkit",
    "utilities",
    "mikro-orm",
    "repository-pattern",
    "helpers",
    "cloner",
    "paginator",
    "bulk-insert"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "peerDependencies": {
    "@cleverJS/condition-builder": "^1.0.4",
    "@mikro-orm/core": "^6.6.7",
    "@mikro-orm/knex": "^6.6.7",
    "knex": "^3.1.0",
    "pg": "^8.0.0",
    "pg-copy-streams": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@cleverJS/condition-builder": {
      "optional": true
    },
    "@mikro-orm/core": {
      "optional": true
    },
    "@mikro-orm/knex": {
      "optional": true
    },
    "knex": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "pg-copy-streams": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cleverJS/condition-builder": "^1.0.4",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@mikro-orm/core": "^6.6.7",
    "@mikro-orm/knex": "^6.6.7",
    "@mikro-orm/postgresql": "^6.6.7",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.10",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.18.13",
    "@types/pg": "^8.16.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.6.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "globals": "^17.0.0",
    "knex": "^3.1.0",
    "pg": "^8.17.2",
    "pg-copy-streams": "^7.0.0",
    "pg-query-stream": "^4.11.2",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18",
    "dotenv": "^17.2.3"
  },
  "packageManager": "pnpm@10.11.1",
  "sideEffects": false
}
